# ==========================================
# Mission Control | NRJ Morgen
# Environment Configuration Template
# ==========================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or .env files with real credentials

# ------------------------------------------
# Supabase Configuration
# ------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Optional: Supabase Service Role (for server-side only - DO NOT EXPOSE TO CLIENT)
# VITE_SUPABASE_SERVICE_KEY=your-service-role-key

# ------------------------------------------
# Brave Search API
# ------------------------------------------
VITE_BRAVE_API_KEY=your-brave-api-key-here

# ------------------------------------------
# Application Settings
# ------------------------------------------
VITE_APP_NAME="Mission Control | NRJ Morgen"
VITE_APP_ENVIRONMENT=development
VITE_API_TIMEOUT=30000

# ------------------------------------------
# Feature Flags
# ------------------------------------------
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_LOGGING=false

# Voice chat integration (disabled by default)
# Set to "true" to enable the voice chat feature
VITE_VOICE_ENABLED=false
# Optional: voice provider endpoint (leave empty until a provider is configured)
# VITE_VOICE_PROVIDER_URL=

# ------------------------------------------
# Optional Integrations
# ------------------------------------------
# VITE_SENTRY_DSN=
# VITE_MIXPANEL_TOKEN=
